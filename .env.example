# ─── Server ───────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8080
APP_NAME=linktag-auth

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=linktag_auth
DB_USER=linktag
DB_PASSWORD=secret
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MINUTES=5

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: make generate-keys
# Then base64-encode: base64 -w 0 private.pem
JWT_PRIVATE_KEY_B64=<base64-encoded-RSA-private-key-PEM>
JWT_PUBLIC_KEY_B64=<base64-encoded-RSA-public-key-PEM>
JWT_ISSUER=linktag-auth
JWT_AUDIENCE=linktag-api
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Requests per second per IP on sensitive endpoints
RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=10

# ─── Migrations ───────────────────────────────────────────────────────────────
MIGRATIONS_PATH=file://migrations
